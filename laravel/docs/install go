# 0) prerequisites
sudo apt update
sudo apt install -y ca-certificates curl tar

# 1) pick arch (prints amd64 or arm64)
dpkg --print-architecture

# 2) set VERSION (change if you want another)
GO_VERSION="1.24.1"

# 3) download Go tarball for your arch
ARCH="$(dpkg --print-architecture)"
case "$ARCH" in
  amd64) GO_ARCH="amd64" ;;
  arm64) GO_ARCH="arm64" ;;
  *) echo "Unsupported arch: $ARCH" && exit 1 ;;
esac

curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-${GO_ARCH}.tar.gz" -o /tmp/go.tgz

# 4) remove old Go (if any), then install
sudo rm -rf /usr/local/go
sudo tar -C /usr/local -xzf /tmp/go.tgz

# 5) add Go to PATH (bash + zsh)
PROFILE_LINE='export PATH="/usr/local/go/bin:$HOME/go/bin:$PATH"'
for f in "$HOME/.profile" "$HOME/.bashrc" "$HOME/.zshrc"; do
  [ -f "$f" ] || continue
  grep -qxF "$PROFILE_LINE" "$f" || echo "$PROFILE_LINE" >> "$f"
done

# 6) load PATH for current shell
export PATH="/usr/local/go/bin:$HOME/go/bin:$PATH"

# 7) verify
go version
go env GOPATH GOMODCACHE
